{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lexicon OS",
  "version": "0.1.0",
  "identifier": "com.lexiconos.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lexicon OS",
        "width": 1340,
        "height": 860,
        "minWidth": 1080,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
